@model List<DemoGitHubWeb.Models.User>
@{
    ViewData["Title"] = "User Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">User List</a>.</p>
</div>

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col">
            <h2>User List</h2>
        </div>
        <div class="col-auto">
            <a href="@Url.Action("ExportToExcel", "User")" class="btn btn-success">
                <i class="fa fa-file-excel-o" aria-hidden="true"></i> Export to Excel
            </a>
        </div>
    </div>
    
    <script>
        function editRow(rowId) {
            document.getElementById('row-display-' + rowId).style.display = 'none';
            document.getElementById('row-edit-' + rowId).style.display = '';
        }
        function cancelEdit(rowId) {
            document.getElementById('row-edit-' + rowId).style.display = 'none';
            document.getElementById('row-display-' + rowId).style.display = '';
        }
        function updateRow(rowId) {
            // You can add logic to update data here
            cancelEdit(rowId);
        }
        function removeRow(rowId) {
            document.getElementById('row-display-' + rowId).remove();
            var editRow = document.getElementById('row-edit-' + rowId);
            if (editRow) editRow.remove();
        }
    </script>
    <table class="table table-bordered">
        <thead>
            <tr>
                <th>STT</th>
                <th>Fullname</th>
                <th>Gender</th>
                <th>Email</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.Count; i++)
            {
                var user = Model[i];
                <tr id="row-display-@user.Id">
                    <td>@user.Id</td>
                    <td>@user.FullName</td>
                    <td>@user.Gender</td>
                    <td>@user.Email</td>
                    <td>
                        <a href="#" class="btn btn-sm btn-primary" onclick="editRow(@user.Id)">Edit</a>
                        <a href="#" class="btn btn-sm btn-success" style="display:none;">Update</a>
                        <a href="#" class="btn btn-sm btn-danger" onclick="removeRow(@user.Id)">Remove</a>
                    </td>
                </tr>
                <tr id="row-edit-@user.Id" style="display:none;">
                    <td>@user.Id</td>
                    <td><input type="text" class="form-control" value="@user.FullName" /></td>
                    <td>
                        <select class="form-control">
                            @if (user.Gender == "Male")
                            {
                                <option value="Male" selected>Male</option>
                                <option value="Female">Female</option>
                            }
                            else
                            {
                                <option value="Male">Male</option>
                                <option value="Female" selected>Female</option>
                            }
                        </select>
                    </td>
                    <td><input type="email" class="form-control" value="@user.Email" /></td>
                    <td>
                        <a href="#" class="btn btn-sm btn-success" onclick="updateRow(@user.Id)">Update</a>
                        <a href="#" class="btn btn-sm btn-secondary" onclick="cancelEdit(@user.Id)">Cancel</a>
                        <a href="#" class="btn btn-sm btn-danger" onclick="removeRow(@user.Id)">Remove</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
